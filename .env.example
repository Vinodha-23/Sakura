# Copy to .env.local and fill in values.
# Free options: Neon (https://neon.tech) OR local Docker Postgres (docker compose up -d)

# Neon or local Postgres connection string
DATABASE_URL="postgresql://sakura:sakura@localhost:5432/sakura"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the app (local or Vercel)
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# When true, forgot-password shows a one-time reset token on screen (no email)
DEMO_MODE="true"

# Free NVIDIA Build API key (nvapi-...) for Documents OCR / optional AI
# Get one at https://build.nvidia.com — preview NIMs, rate-limited
NVIDIA_API_KEY=""

# Optional: override the seeded demo account (npm run db:seed)
# Leave unset to use the built-in demo login.
SEED_DEMO_EMAIL=""
SEED_DEMO_PASSWORD=""
